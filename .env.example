# ─── Google Gemini ────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Use Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/shopsense
# Or local Docker: mongodb://localhost:27017/shopsense
MONGODB_URI=mongodb://localhost:27017/shopsense

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=shopsense_products

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Pinecone (optional, for production) ──────────────────────────────────────
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_INDEX=shopsense
